# SAKN Environment Variables
# Copy to .env and fill in values for local development

# Database
# Priority: DATABASE_URL (explicit override) > assembly from POSTGRES_* components > SQLite default
# Direct PostgreSQL URL (optional — set this to bypass component assembly)
DATABASE_URL=sqlite+aiosqlite:///./sakn.db
# PostgreSQL components (used when DATABASE_URL is not explicitly set)
POSTGRES_USER=sakn
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sakn

# Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me-in-production-use-at-least-32-characters
# Health check token for /health/full (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
HEALTH_FULL_TOKEN=

# PostgreSQL password (required in production; generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
POSTGRES_PASSWORD=

# Redis password (required; generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# Server
HOST=0.0.0.0
PORT=8000

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Reverse proxy trust — number of trusted hops between the client and the app.
# See docs/adr/003-proxy-trust-policy.md
# 0 = direct exposure (no proxy)
# 1 = single proxy (Caddy/Traefik/nginx — default for the prod compose profile)
# 2 = two proxies (e.g. CDN + ingress controller)
TRUSTED_PROXY_HOPS=1

# Domain name (required for TLS in production)
DOMAIN=sakn.example.com

# CORS
CORS_ORIGINS=http://localhost:5173

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@sakn.example.com

# Email verification
EMAIL_VERIFICATION_REQUIRED=true
